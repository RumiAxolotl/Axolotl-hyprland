{
    "label": "lock",
    "action": "hyprlock",
    "text": "Lock",
    "keybind": "l"
}
{
    "label": "reboot",
    "action": "systemctl reboot",
    "text": "Reboot",
    "keybind": "r"
}
{
    "label": "shutdown",
    "action": "systemctl poweroff",
    "text": "Shutdown",
    "keybind": "s"
}
{
    "label": "logout",
    "action": "hyprctl dispatch 'hl.dsp.exit()'",
    "text": "Logout",
    "keybind": "e"
}
{
    "label": "suspend",
    "action": "systemctl suspend",
    "text": "Suspend",
    "keybind": "u"
}