[global]
    follow = mouse
    indicate_hidden = yes

    # Fixed syntax and matched Hyprland gaps
    offset = (8, 8)

    # Removed invalid notification_height setting
    separator_height = 2

    padding = 10
    horizontal_padding = 10
    text_icon_padding = 10
    
    # Matched Hyprland border size and rounding
    frame_width = 2
    corner_radius = 8

    sort = yes
    idle_threshold = 120
    font = Maple Mono NF 10
    line_height = 0
    markup = full
    alignment = left
    vertical_alignment = center
    show_age_threshold = 60
    word_wrap = yes
    stack_duplicates = true
    hide_duplicate_count = false

    show_indicators = yes

    min_icon_size = 0
    max_icon_size = 64

    # Updated to the light mode Reversal-purple icon paths
    icon_path = /usr/share/icons/Reversal-purple/16x16/status/:/usr/share/icons/Reversal-purple/16x16/devices/:/usr/share/icons/Reversal-purple/16x16/actions/:/usr/share/icons/Reversal-purple/16x16/animations/:/usr/share/icons/Reversal-purple/16x16/apps/:/usr/share/icons/Reversal-purple/16x16/categories/:/usr/share/icons/Reversal-purple/16x16/emblems/:/usr/share/icons/Reversal-purple/16x16/emotes/:/usr/share/icons/Reversal-purple/16x16/devices/mimetypes:/usr/share/icons/Reversal-purple/16x16/panel/:/usr/share/icons/Reversal-purple/16x16/places/

    title = Dunst
    class = Dunst

    timeout = 5

    # Monochrome minimal styling to match your Hyprland/Waybar
    frame_color = "#cdd6f4"
    separator_color = frame

    mouse_left_click = do_action, close_current
    mouse_middle_click = close_all
    mouse_right_click = close_current

[urgency_low]
    # Latte Base & Text
    background = "#eff1f5"
    foreground = "#4c4f69"

[urgency_normal]
    # Latte Base & Text
    background = "#eff1f5"
    foreground = "#4c4f69"

[urgency_critical]
    # Latte Base & Text
    background = "#eff1f5"
    foreground = "#4c4f69"
    # Latte Peach for critical alerts
    frame_color = "#fe640b"

# --- Custom Rules ---

[ignore_volume]
    appname = "Volume"
    history_ignore = yes

[ignore_brightness]
    appname = "Brightness"
    history_ignore = yes